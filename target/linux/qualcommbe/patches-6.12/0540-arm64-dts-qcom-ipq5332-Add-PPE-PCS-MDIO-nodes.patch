From: Kamil Bienkiewicz <perceivalpercy@gmail.com>
Date: Sat, 16 May 2026 14:00:00 +0000
Subject: [PATCH] arm64: dts: qcom: ipq5332: Add PPE/PCS/MDIO/EDMA base nodes

Adds the mainline qcom-ppe + pcs-qcom-ipq9574 device tree skeleton
for IPQ5332. Modeled on IPQ9574 (same NSS-PPE silicon at same register
layout); reduced to two PCS instances (IPQ5332 has 2 UNIPHY vs 3 on
IPQ9574) and trimmed to clocks/interconnects IPQ5332's nsscc exposes.

PPE uses NSS_CC_PPE_SWITCH_CLK_ARES as its reset (ipq9574 had an
aggregate PPE_FULL_RESET which IPQ5332 nsscc doesn't expose). EDMA
child node uses per-clock reset for the same reason.

Signed-off-by: Kamil Bienkiewicz <perceivalpercy@gmail.com>
---
--- a/arch/arm64/boot/dts/qcom/ipq5332.dtsi
+++ b/arch/arm64/boot/dts/qcom/ipq5332.dtsi
@@ -653,6 +653,121 @@
 			#reset-cells = <1>;
 			#interconnect-cells = <1>;
 		};
+
+		mdio: mdio@90000 {
+			compatible = "qcom,ipq5332-mdio", "qcom,ipq4019-mdio";
+			reg = <0x00090000 0x64>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			clocks = <&gcc GCC_MDIO_AHB_CLK>;
+			clock-names = "gcc_mdio_ahb_clk";
+			status = "disabled";
+		};
+
+		pcs0: ethernet-pcs@7a00000 {
+			compatible = "qcom,ipq5332-pcs";
+			reg = <0x07a00000 0x10000>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			clocks = <&gcc GCC_UNIPHY0_SYS_CLK>,
+				 <&gcc GCC_UNIPHY0_AHB_CLK>;
+			clock-names = "sys", "ahb";
+			resets = <&gcc GCC_UNIPHY0_XPCS_ARES>;
+			#clock-cells = <1>;
+			status = "disabled";
+
+			pcs0_ch0: pcs-mii@0 {
+				reg = <0>;
+				clocks = <&nsscc NSS_CC_UNIPHY_PORT1_RX_CLK>,
+					 <&nsscc NSS_CC_UNIPHY_PORT1_TX_CLK>;
+				clock-names = "rx", "tx";
+			};
+		};
+
+		pcs1: ethernet-pcs@7a10000 {
+			compatible = "qcom,ipq5332-pcs";
+			reg = <0x07a10000 0x10000>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			clocks = <&gcc GCC_UNIPHY1_SYS_CLK>,
+				 <&gcc GCC_UNIPHY1_AHB_CLK>;
+			clock-names = "sys", "ahb";
+			resets = <&gcc GCC_UNIPHY1_XPCS_ARES>;
+			#clock-cells = <1>;
+			status = "disabled";
+
+			pcs1_ch0: pcs-mii@0 {
+				reg = <0>;
+				clocks = <&nsscc NSS_CC_UNIPHY_PORT2_RX_CLK>,
+					 <&nsscc NSS_CC_UNIPHY_PORT2_TX_CLK>;
+				clock-names = "rx", "tx";
+			};
+		};
+
+		qcom_ppe: ethernet@3a000000 {
+			compatible = "qcom,ipq5332-ppe";
+			reg = <0x3a000000 0xbef800>;
+			ranges;
+			#address-cells = <1>;
+			#size-cells = <1>;
+			clocks = <&nsscc NSS_CC_PPE_SWITCH_CLK>,
+				 <&nsscc NSS_CC_PPE_SWITCH_CFG_CLK>,
+				 <&nsscc NSS_CC_PPE_SWITCH_IPE_CLK>,
+				 <&nsscc NSS_CC_PPE_SWITCH_BTQ_CLK>;
+			clock-names = "ppe",
+				      "ppe_cfg",
+				      "ppe_ipe",
+				      "ppe_btq";
+			resets = <&nsscc NSS_CC_PPE_SWITCH_CLK_ARES>;
+			interconnects = <&nsscc MASTER_NSSNOC_PPE
+					 &nsscc SLAVE_NSSNOC_PPE>,
+					<&nsscc MASTER_NSSNOC_PPE_CFG
+					 &nsscc SLAVE_NSSNOC_PPE_CFG>,
+					<&gcc MASTER_NSSNOC_QOSGEN_REF
+					 &gcc SLAVE_NSSNOC_QOSGEN_REF>,
+					<&gcc MASTER_NSSNOC_TIMEOUT_REF
+					 &gcc SLAVE_NSSNOC_TIMEOUT_REF>;
+			interconnect-names = "ppe",
+					     "ppe_cfg",
+					     "qos_gen",
+					     "timeout_ref";
+			status = "disabled";
+
+			edma {
+				compatible = "qcom,ipq9574-edma";
+				clocks = <&nsscc NSS_CC_PPE_EDMA_CLK>,
+					 <&nsscc NSS_CC_PPE_EDMA_CFG_CLK>;
+				clock-names = "edma", "edma-cfg";
+				resets = <&nsscc NSS_CC_PPE_EDMA_CLK_ARES>;
+				reset-names = "edma_rst";
+				interrupts = <GIC_SPI 163 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 164 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 165 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 166 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 167 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 168 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 169 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 170 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 171 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 172 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 173 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 174 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 139 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 140 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 141 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 142 IRQ_TYPE_LEVEL_HIGH>,
+					     <GIC_SPI 191 IRQ_TYPE_LEVEL_HIGH>;
+				interrupt-names = "edma_txcmpl_4",  "edma_txcmpl_5",
+						  "edma_txcmpl_6",  "edma_txcmpl_7",
+						  "edma_txcmpl_8",  "edma_txcmpl_9",
+						  "edma_txcmpl_10", "edma_txcmpl_11",
+						  "edma_txcmpl_12", "edma_txcmpl_13",
+						  "edma_txcmpl_14", "edma_txcmpl_15",
+						  "edma_rxdesc_12", "edma_rxdesc_13",
+						  "edma_rxdesc_14", "edma_rxdesc_15",
+						  "edma_misc";
+			};
+		};
 	};
 
 	timer {
