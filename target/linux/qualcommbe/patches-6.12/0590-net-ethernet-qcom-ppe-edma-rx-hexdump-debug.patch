From: Kamil Bienkiewicz <perceivalpercy@gmail.com>
Date: Sun, 24 May 2026 11:30:00 +0000
Subject: [PATCH] net: ethernet: qcom: ppe: edma: rx hex-dump diagnostic

Diagnostic-only — log the first 200 frames arriving at eth0's EDMA RX
with the first 28 bytes, plus a quick tag classification (unicast DA
or multicast DA, decoded source-port-low-nibble, decoded port-mask).
Used to reverse-engineer the RTL8372N tag layout — specifically to
see whether unicast trapped frames use a different bit-encoding than
flooded broadcast/multicast frames.

Signed-off-by: Kamil Bienkiewicz <perceivalpercy@gmail.com>
---
--- a/drivers/net/ethernet/qualcomm/ppe/edma_rx.c
+++ b/drivers/net/ethernet/qualcomm/ppe/edma_rx.c
@@ -368,6 +368,34 @@
 	rx_stats->rx_nr_frag_pkts += (u64)page_mode;
 	u64_stats_update_end(&rx_stats->syncp);
 
+	{
+		static unsigned int diag_count;
+
+		if (diag_count < 200) {
+			const u8 *d = skb->data;
+			bool mcast = (d[0] & 0x01);
+			u16 etype = (d[12] << 8) | d[13];
+			u8 proto = d[14];
+			u16 tag_w2 = (d[16] << 8) | d[17];
+			u16 tag_w3 = (d[18] << 8) | d[19];
+			u8 port_low = tag_w3 & 0xF;
+			u8 port_hi = (tag_w3 >> 8) & 0xF;
+			u8 mask = hweight16(tag_w3 & 0x7FFF);
+
+			diag_count++;
+			pr_info("edma_rx diag[%u]: ndev=%s len=%u %s DA=%pM SA=%pM ety=0x%04x proto=0x%02x w2=0x%04x w3=0x%04x port_lo=%u port_hi=%u bits_set=%u first28:%*phN\n",
+				diag_count,
+				skb->dev ? skb->dev->name : "?",
+				skb->len,
+				mcast ? "MCAST" : "UCAST",
+				d, d + 6,
+				etype, proto, tag_w2, tag_w3,
+				port_low, port_hi, mask,
+				min_t(unsigned int, 28, skb_headlen(skb)),
+				skb->data);
+		}
+	}
+
 	skb->protocol = eth_type_trans(skb, skb->dev);
 	if (skb->dev->features & NETIF_F_GRO)
 		napi_gro_receive(&rxdesc_ring->napi, skb);
