 	.halt_reg = 0x57c,
-	.halt_check = BRANCH_HALT,
+	.halt_check = BRANCH_HALT_SKIP,
 	.clkr = {
 		.enable_reg = 0x57c,
 		.enable_mask = BIT(0),
@@ -1022,7 +1022,7 @@

 static struct clk_branch nss_cc_uniphy_port1_tx_clk = {
 	.halt_reg = 0x580,
-	.halt_check = BRANCH_HALT,
+	.halt_check = BRANCH_HALT_SKIP,
 	.clkr = {
 		.enable_reg = 0x580,
