From: Kamil Bienkiewicz <perceivalpercy@gmail.com>
Date: Thu, 21 May 2026 14:45:00 +0000
Subject: [PATCH] net: pcs: qcom-ipq9574: debug — dump PCS0 region after
 config_mode

Compare vendor's running PCS0 register state vs ours, line by line.
Vendor's dump (from-ap2/vendor-pcs0-full-2026-05-22.txt) shows many
non-zero registers in the 0x000-0x300 range that mainline never writes;
diffing live OUR state against vendor lets us find the gap.

Signed-off-by: Kamil Bienkiewicz <perceivalpercy@gmail.com>
---
--- a/drivers/net/pcs/pcs-qcom-ipq9574.c
+++ b/drivers/net/pcs/pcs-qcom-ipq9574.c
@@ -391,6 +391,38 @@
 		return ret;
 	msleep(10);

+	{
+		unsigned int mc, mc2, ca, pr;
+		unsigned int val, off;
+
+		regmap_read(qpcs->regmap, PCS_MODE_CTRL,    &mc);
+		regmap_read(qpcs->regmap, PCS_MISC2,        &mc2);
+		regmap_read(qpcs->regmap, PCS_CALIBRATION,  &ca);
+		regmap_read(qpcs->regmap, PCS_PLL_RESET,    &pr);
+		dev_warn(qpcs->dev,
+			 "DBG config_mode EXIT iface=%d MODE_CTRL=0x%08x MISC2=0x%08x CALIB=0x%08x PLL_RESET=0x%08x\n",
+			 interface, mc, mc2, ca, pr);
+
+		/* Dump PCS0 0x000-0x300 in 8 regs per line for diffing
+		 * against the vendor capture.
+		 */
+		for (off = 0; off < 0x500; off += 0x20) {
+			char buf[160];
+			int n = 0, j;
+
+			for (j = 0; j < 8; j++) {
+				if (regmap_read(qpcs->regmap,
+						off + j * 4, &val))
+					val = 0xdeadbeef;
+				n += snprintf(buf + n, sizeof(buf) - n,
+					      " %08x", val);
+				if ((unsigned)n >= sizeof(buf))
+					break;
+			}
+			dev_warn(qpcs->dev,
+				 "DBG pcs0[%03x]:%s\n", off, buf);
+		}
+	}
 	qpcs->interface = interface;

 	/* Configure the RX and TX clock to NSSCC as 125M or 312.5M based
