. /lib/functions/uci-defaults.sh
. /lib/functions/system.sh

ipq53xx_setup_interfaces()
{
	local board="$1"

	case "$board" in
	glinet,gl-be9300)
		# LAN-only: the AP runs off the LAN-uplink (trunk on lan3).
		# eth1/WAN is deliberately NOT assigned — bringing up the WAN
		# USXGMII PCS wedges the nss_cc port1 RCG (UPDATE-STUCK) and
		# triggers a watchdog reset (WDog 0x4 / reason 0x69) at ~26s.
		ucidef_set_interface_lan "lan1 lan2 lan3 lan4"
		;;
	*)
		echo "Unsupported hardware. Network interfaces not initialized"
		;;
	esac
}

board_config_update
board=$(board_name)
ipq53xx_setup_interfaces $board
board_config_flush

exit 0
